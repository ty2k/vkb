{
  "name": "vkb-react",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build:js": "rolldown -c rolldown.config.ts",
    "build:types": "tsc -p tsconfig.types.json",
    "build:dts": "rolldown -c rolldown.config.dts.ts",
    "build:remove-full-types": "rm -rf dist/types",
    "build": "npm run clean && npm run build:js && npm run build:types && npm run build:dts && npm run build:remove-full-types",
    "build-vite": "tsc -b && vite build",
    "format:check": "npx prettier . --check",
    "format:write": "npx prettier . --write",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:watch": "npx vitest .",
    "test": "npx vitest run ."
  },
  "peerDependencies": {
    "react": "^16.14.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.14.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/babel__core": "7.20.5",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "rolldown": "1.0.3",
    "rolldown-plugin-dts": "0.25.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
